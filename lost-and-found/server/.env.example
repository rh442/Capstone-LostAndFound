# =============================================================
# Lost & Found — server environment variables (example)
# Copy this file to `.env` in the same directory and fill in
# real values. Never commit the real `.env` (it is gitignored).
# =============================================================


# -------------------------------------------------------------
# Database selector
# -------------------------------------------------------------
# Chooses which database the server connects to.
#   "local"    -> use the local Postgres settings below
#   "supabase" -> use the Supabase connection string below
DB_TARGET=


# -------------------------------------------------------------
# Local Postgres (only used when DB_TARGET=local)
# -------------------------------------------------------------
# Hostname of your local Postgres server (usually localhost).
DB_HOST=

# Port your local Postgres listens on (default 5432).
DB_PORT=

# Name of the local database to connect to.
DB_NAME=

# Postgres username with access to DB_NAME.
DB_USER=

# Password for DB_USER. Leave empty if your local Postgres
# uses trust/peer authentication.
DB_PASSWORD=


# -------------------------------------------------------------
# Anthropic API (chatbot)
# -------------------------------------------------------------
# API key for Claude, used by the in-app chatbot.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=


# -------------------------------------------------------------
# Supabase (only used when DB_TARGET=supabase)
# -------------------------------------------------------------
# Full Postgres connection string from Supabase
# (Project Settings -> Database -> Connection string -> Session Pooler).
SUPABASE_DATABASE_URL=

# Your Supabase project URL
# (Project Settings -> API -> Project URL).
SUPABASE_URL=

# Service role key for server-side access
# (Project Settings -> API -> service_role).
# WARNING: bypasses RLS — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=


# -------------------------------------------------------------
# App settings
# -------------------------------------------------------------
# Secret used to sign/verify JWTs for user sessions.
# Use a long random string; rotating it logs everyone out.
JWT_SECRET=

# Port the Express server listens on (e.g. 4000).
PORT=
